# Prisma Database Connection
# Note: Prisma requires the full connection string here. It must match your Docker Postgres variables below.
DATABASE_URL="postgresql://user:password@localhost:5432/db_name?schema=public"

# NextAuth Configuration
NEXTAUTH_SECRET="generate-a-secure-secret-key-here"

# Gemini AI Key
GOOGLE_GENERATIVE_AI_API_KEY="your-gemini-api-key-here"

# Docker Postgres Variables (Used by docker-compose to initialize the DB container)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=db_name
DB_PORT=5432
